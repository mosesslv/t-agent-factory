    return {
        "items": [
            {
                **item,
                "detail": review_packet_detail(item),
            }
            for item in queue["items"]
        ]
    }


def extend_item_lines(lines, items, fallback="- none", limit=6):
    if not items:
        lines.append(fallback)
        return
    for item in items[:limit]:
        lines.append(f"- {item}")
    if len(items) > limit:
        lines.append(f"- ... {len(items) - limit} more")


def extend_check_lines(lines, checks):
    if not checks:
        lines.append("- none")
        return
    for item in checks:
        if item["ok"]:
            label = "PASS"
        elif item["severity"] == "warning":
            label = "WARN"
        else:
            label = "FAIL"
        lines.append(f"- {label} {item['name']}")


def render_review_packet_markdown(payload, generated_by="tools/kb review-packet"):
    now = today()
    lines = [
        "---",
        "type: index",
        "status: active",
        f"created: {now}",
        f"updated: {now}",
        f"generated_by: {generated_by}",
        "---",
        "",
        "# Generated Review Packet",
        "",
        "本文件汇总当前最高优先级人工审阅任务。它只展示上下文和建议命令，不代表已经人工确认。",
        "",
    ]
    if not payload["items"]:
        lines.extend(["## Tasks", "", "- none"])
        return "\n".join(lines) + "\n"
    for index, item in enumerate(payload["items"], start=1):
        detail = item.get("detail", {})
        label = item.get("id") or item["path"]
        lines.extend(
            [
                f"## {index}. {label}",
                "",
                f"- Kind: `{item['kind']}`",
                f"- Priority: `{item['priority']}`",
                f"- Reason: {item['reason']}",
                f"- Topic: `{item['topic']}`",
                f"- Next action: `{item['next_action']}`",
                f"- Preview: `{item['preview_command']}`",
                f"- Path: `{item['path']}`",
                "",
                "### Decision Commands",
                "",
            ]
        )
        if item["decision_commands"]:
            for command in item["decision_commands"]:
                lines.append(f"- `{command}`")
        else:
            lines.append("- none")
        if detail.get("error"):
            lines.extend(["", "### Detail Error", "", f"- {detail['error']}"])
            continue
        if item["kind"] == "source-note":
            lines.extend(["", "### Summary", ""])
            extend_item_lines(lines, detail.get("summary_items", []))
            lines.extend(["", "### Initial Judgment", ""])
            extend_item_lines(lines, detail.get("judgment_items", []))
            lines.extend(["", "### Linked Sessions", ""])
            sessions = detail.get("linked_sessions", [])
            if sessions:
                for session in sessions:
                    lines.append(f"- `{session.get('id') or session.get('path')}` {session.get('status', '')} {session.get('stage', '')} `{session.get('path', '')}`")
            else:
                lines.append("- none")
        elif item["kind"] == "distillation-candidate":
            lines.extend(["", "### Stable Judgments", ""])
            extend_item_lines(lines, detail.get("stable_judgments", []))
            lines.extend(["", "### Decision Candidates", ""])
            extend_item_lines(lines, detail.get("decision_candidates", []))
            lines.extend(["", "### Source Sessions", ""])
            sessions = detail.get("source_sessions", [])
            if sessions:
                for session in sessions:
                    lines.append(f"- `{session.get('id') or session.get('ref')}` {session.get('status', '')} {session.get('stage', '')} `{session.get('path', '')}`")
            else:
                lines.append("- none")
            lines.extend(["", "### Source Debates", ""])
            debates = detail.get("source_debates", [])
            if debates:
                for debate in debates:
                    lines.append(f"- `{debate.get('id') or debate.get('ref')}` {debate.get('status', '')} {debate.get('stage', '')} `{debate.get('path', '')}`")
            else:
                lines.append("- none")
            lines.extend(["", "### Planned Files", ""])
            planned = detail.get("planned_files", [])
            if planned:
                for planned_file in planned:
                    exists = "exists" if planned_file.get("exists") else "new"
                    lines.append(f"- {planned_file.get('operation', '')} `{planned_file.get('role', '')}` {exists} `{planned_file.get('path', '')}`")
            else:
                lines.append("- none")
        elif item["kind"] == "debate-session":
            lines.extend(["", "### Round 3 Convergence", ""])
            extend_item_lines(lines, detail.get("round_3_items", []), limit=8)
            lines.extend(["", "### Distillation Suggestions", ""])
            extend_item_lines(lines, detail.get("distillation_suggestions", []), limit=8)
            lines.extend(["", "### Drafted Distillations", ""])
            drafted = detail.get("drafted_distillations", [])
            if drafted:
                for distillation in drafted:
                    lines.append(f"- `{distillation.get('id') or distillation.get('path')}` {distillation.get('status', '')} {distillation.get('promotion_status', '')} `{distillation.get('path', '')}`")
            else:
                lines.append("- none")
        lines.extend(["", "### Checks", ""])
        extend_check_lines(lines, detail.get("checks", []))
        lines.append("")
    return "\n".join(lines).rstrip() + "\n"


