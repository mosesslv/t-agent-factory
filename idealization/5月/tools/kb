def extract_numbered_section(text: str, heading: str):
    pattern = re.compile(rf"^### {re.escape(heading)}\s*$", re.MULTILINE)
    match = pattern.search(text)
    if not match:
        return []
    rest = text[match.end():]
    next_heading = re.search(r"^### |\n## ", rest, re.MULTILINE)
    section = rest[: next_heading.start()] if next_heading else rest
    items = []
    for line in section.splitlines():
        item = re.match(r"^\s*\d+\.\s+(.*)", line)
        if item:
            items.append(item.group(1).strip())
    return items


def extract_markdown_section(text: str, heading: str, level: int = 2):
    marker = "#" * level
    pattern = re.compile(rf"^{re.escape(marker)} {re.escape(heading)}\s*$", re.MULTILINE)
    match = pattern.search(text)
    if not match:
        return ""
    rest = text[match.end():]
    next_heading = re.search(rf"^#{{1,{level}}} ", rest, re.MULTILINE)
    return rest[: next_heading.start()] if next_heading else rest


def has_list_content(section: str):
