def load_distillation_arg(path_arg: str):
    path = (ROOT / path_arg).resolve()
    if not path.exists() or ROOT not in path.parents:
        raise ValueError(f"Distillation file not found in workspace: {path_arg}")
    data, error = parse_frontmatter(path)
    if error:
        raise ValueError(f"{rel(path)}: {error}")
    if data.get("type") != "distillation-candidate":
        raise ValueError(f"{rel(path)}: not a distillation-candidate")
    return path, data


def command_approve_distillation(args):
    try:
        path, data = load_distillation_arg(args.distillation)
    except ValueError as exc:
        print(f"ERROR {exc}", file=sys.stderr)
        return 1
    if data.get("promotion_status") != "pending-human-review":
        print(
            f"ERROR expected promotion_status pending-human-review, got {data.get('promotion_status')}",
            file=sys.stderr,
        )
        return 1
    replace_frontmatter_value(path, "promotion_status", "approved-for-promotion")
    replace_frontmatter_value(path, "updated", today())
    print(f"Approved {rel(path)}")
    return 0


def command_review_distillation(args):
    try:
        path, data = load_distillation_arg(args.distillation)
    except ValueError as exc:
        print(f"ERROR {exc}", file=sys.stderr)
        return 1

    current = data.get("promotion_status")
    if current == "promoted":
        print(f"ERROR {rel(path)} is already promoted", file=sys.stderr)
        return 1

    if args.action == "approve":
        if current != "pending-human-review":
            print(
                f"ERROR expected promotion_status pending-human-review, got {current}",
                file=sys.stderr,
            )
            return 1
        checks = distillation_check_items(path, data)
        if not args.skip_check and not distillation_checks_pass(checks):
            print_distillation_checks(path, checks)
            print("ERROR distillation checks failed; use needs-revision or fix the candidate before approval", file=sys.stderr)
            return 1
        promotion_status = "approved-for-promotion"
        status = "reviewed"
    elif args.action == "reject":
        promotion_status = "rejected"
        status = "reviewed"
    else:
        promotion_status = "pending-human-review"
        status = "draft"

    replace_frontmatter_value(path, "promotion_status", promotion_status)
    replace_frontmatter_value(path, "status", status)
    replace_frontmatter_value(path, "updated", today())
    append_review_log(path, args.action, args.reviewer, args.note or "")
    print(f"Reviewed distillation {rel(path)} as {args.action}")
    return 0


