def main():
    parser = argparse.ArgumentParser(prog="kb", description="Knowledge Workbench helper CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    validate = sub.add_parser("validate", help="validate typed Markdown frontmatter")
    validate.set_defaults(func=command_validate)

    status = sub.add_parser("status", help="show typed file status and pending promotions")
    status.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    status.set_defaults(func=command_status)

    version_status = sub.add_parser("version-status", help="show read-only git version status")
    version_status.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    version_status.add_argument("--limit", type=int, default=5, help="number of recent commits")
    version_status.set_defaults(func=command_version_status)

    agent_brief = sub.add_parser("agent-brief", help="show read-only handoff context for any agent client")
    agent_brief.add_argument("--json", action="store_true", help="emit machine-readable JSON")
