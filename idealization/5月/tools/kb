                reason=esc(item.get("reason", "")),
                next_action=esc(item.get("next_action", "")),
                topic=esc(topic),
                path=esc(path),
                button=copy_button(command),
            )
        )
    if not decision_rows:
        decision_rows.append('<tr><td colspan="6" class="empty">No review tasks</td></tr>')

    gate_rows = []
    for item in dashboard["gate_status"]:
        gate_rows.append(
            '<tr><td>{label}</td><td>{count}</td><td><span class="state state-{state}">{state}</span></td><td>{next}</td></tr>'.format(
