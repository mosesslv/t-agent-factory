def rel(path: Path) -> str:
    return path.relative_to(ROOT).as_posix()


def slugify(text: str) -> str:
    text = text.strip()
    text = re.sub(r"[\\/:*?\"<>|#\[\]`]+", "-", text)
    text = re.sub(r"\s+", "-", text)
    return text.strip("-") or "untitled"


def today() -> str:
