    return False


def has_non_placeholder_content(section: str):
    for line in section.splitlines():
        stripped = line.strip()
        if not stripped or stripped in {"-", "- [ ]", "- [x]"}:
            continue
        if stripped.startswith("- [ ]") or stripped.startswith("- [x]"):
            continue
        if stripped in {"- 可信度：", "- 与当前知识库关系：", "- 是否建议进入 session："}:
            continue
        if stripped.startswith("- 可信度：") and stripped.endswith("："):
            continue
        if stripped.startswith("- 与当前知识库关系：") and stripped.endswith("："):
            continue
        if stripped.startswith("- 是否建议进入 session：") and stripped.endswith("："):
            continue
        return True
    return False


