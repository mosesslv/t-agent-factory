def extract_bullets(section: str, limit: int = 5):
    bullets = []
    for line in section.splitlines():
        stripped = line.strip()
        if stripped.startswith("- ") and len(stripped) > 2:
            bullets.append(stripped[2:].strip())
        numbered = re.match(r"^\d+\.\s+(.*)", stripped)
        if numbered:
            bullets.append(numbered.group(1).strip())
        if len(bullets) >= limit:
            break
    return bullets


def is_debate_placeholder(item: str):
    stripped = item.strip()
    if not stripped or stripped == "-":
        return True
    if f"- {stripped}" in DEBATE_PLACEHOLDER_LABELS:
        return True
    if re.match(r"^(Claim|Evidence|Risk|Question|Recommendation):\s*$", stripped):
        return True
    if re.match(r"^[^：:]{1,24}[：:]\s*$", stripped):
        return True
    return False


def debate_bullets(section: str, limit: int = 20):
    items = []
    for item in extract_bullets(section, limit=100):
        if is_debate_placeholder(item):
            continue
        items.append(item)
        if len(items) >= limit:
            break
    return items


def has_debate_content(section: str):
    return bool(debate_bullets(section, limit=1))


