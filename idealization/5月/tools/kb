def decision_guide_payload(limit=5, kind=None, ready_only=False, review_payload=None):
    payload = review_payload if review_payload is not None else review_queue_payload(limit=limit, kind=kind, ready_only=ready_only)
    items = payload["items"][:limit]
    guided = []
    for item in items:
        detail = review_packet_detail(item)
        guided.append(
            {
                **item,
                "detail_error": detail.get("error", ""),
                "evidence_summary": decision_guide_evidence(item, detail),
                "decision_options": decision_guide_options(item, detail),
                "protected": item["kind"] in {"source-note", "distillation-candidate"},
            }
        )
    return {
        "updated": today(),
        "items": guided,
        "guardrails": [
            "This guide is read-only and must not be treated as human approval.",
            "Use preview commands before any review decision.",
            "Only run review-source, review-distillation, approve-distillation, or promote --confirm after explicit human confirmation.",
            "Prefer needs-revision when evidence, wording, target path, or scope is uncertain.",
        ],
    }


def render_decision_guide_markdown(payload, generated_by="tools/kb decision-guide"):
