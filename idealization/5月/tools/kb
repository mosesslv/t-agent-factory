def workspace_dashboard_payload(rows=None, queue=None, review_payload=None, tool_catalog=None, limit=5):
    rows = rows if rows is not None else list(typed_files())
    workbench_payload = queue if queue is not None else queue_payload()
    review_payload = review_payload if review_payload is not None else review_queue_payload(limit=limit, queue=workbench_payload)
    tool_catalog = tool_catalog if tool_catalog is not None else tool_catalog_payload()
    type_counts = Counter(data.get("type", "") for _, data in rows)
    status_counts = Counter(data.get("status", "") for _, data in rows)
    source_ready = [
        item
        for item in workbench_payload["source_notes"]
        if item["check_ok"] and item["review_status"] != "reviewed"
    ]
    source_needs_completion = [
        item
        for item in workbench_payload["source_notes"]
        if not item["check_ok"]
    ]
    distillation_ready = [
        item
        for item in workbench_payload["pending_promotions"]
        if item["promotion_status"] == "pending-human-review"
        and item["check_ok"]
        and item["promotion_conflict_free"]
    ]
    distillation_approved = [
        item
        for item in workbench_payload["pending_promotions"]
        if item["promotion_status"] == "approved-for-promotion"
        and item["promotion_conflict_free"]
    ]
    high_risk_tools = [
        item
        for item in tool_catalog["tools"]
        if item["permission_class"] in {"review-decision", "formal-structure-write", "formal-knowledge-write"}
    ]
    return {
        "updated": today(),
        "title": "Knowledge Workbench Dashboard",
        "summary": {
            "total_typed_files": len(rows),
            "types": dict(type_counts),
            "statuses": dict(status_counts),
