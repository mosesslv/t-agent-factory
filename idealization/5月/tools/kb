def review_packet_detail(item: dict):
    try:
        if item["kind"] == "source-note":
            path, data = load_typed_path(item["path"], "source-note", "Source note")
            return source_review_payload(path, data)
        if item["kind"] == "distillation-candidate":
            path, data = load_distillation_arg(item["path"])
            return distillation_review_payload(path, data)
        if item["kind"] == "debate-session":
            path, data = load_debate_arg(item["path"])
            return debate_review_payload(path, data)
    except ValueError as exc:
        return {"error": str(exc)}
    return {"error": f"unsupported review kind: {item.get('kind', '')}"}


