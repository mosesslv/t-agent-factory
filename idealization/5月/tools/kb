def render_rag_scope_markdown(payload, generated_by="tools/kb rag-scope"):
    now = today()

    def table_cell(value):
        if isinstance(value, list):
            value = ", ".join(value)
        return str(value).replace("|", "\\|")

    lines = [
        "---",
        "type: index",
        "status: active",
        f"created: {now}",
        f"updated: {now}",
        f"generated_by: {generated_by}",
        "---",
        "",
        "# Generated RAG Scope",
        "",
        "本文件定义 Knowledge Workbench 的检索和 RAG 范围。它只描述读取优先级和风险，不代表人工审阅或正式入库。",
        "",
        "## Retrieval Policy",
        "",
    ]
    for key, value in payload["retrieval_policy"].items():
        lines.append(f"- {key}: {value}")
    lines.extend(["", "## Scope Counts", ""])
    for scope, count in sorted(payload["scope_counts"].items()):
        lines.append(f"- `{scope}`: `{count}`")
    for scope in ["include", "cautious", "exclude"]:
        lines.extend(
            [
                "",
                f"## {scope.title()}",
                "",
                "| ID | Priority | Audience | Path | Reason | Conditions | Risk |",
                "|---|---|---|---|---|---|---|",
            ]
        )
        scoped = [item for item in payload["items"] if item["scope"] == scope]
        if not scoped:
            lines.append("| - | - | - | - | - | - | - |")
        for item in scoped:
            lines.append(
                "| {id} | {priority} | `{audience}` | `{path}` | {reason} | {conditions} | `{risk}` |".format(
                    id=table_cell(item["id"]),
                    priority=table_cell(item["priority"]),
                    audience=table_cell(item["audience"]),
                    path=table_cell(item["path"]),
                    reason=table_cell(item["reason"]),
                    conditions=table_cell("; ".join(item["conditions"])),
                    risk=table_cell(item["risk"]),
                )
            )
    lines.extend(
        [
            "",
            "## Recommended Query Order",
            "",
            "| Step | Label | Scope | Paths | Use For |",
            "|---:|---|---|---|---|",
        ]
    )
    for item in payload["recommended_query_order"]:
        lines.append(
            "| {step} | {label} | `{scope}` | `{paths}` | {use_for} |".format(
                step=item["step"],
                label=table_cell(item["label"]),
                scope=table_cell(item["scope"]),
                paths=table_cell(item["paths"]),
                use_for=table_cell(item["use_for"]),
            )
        )
    lines.extend(["", "## Guardrails", ""])
    lines.extend(f"- {item}" for item in payload["guardrails"])
    return "\n".join(lines).rstrip() + "\n"


