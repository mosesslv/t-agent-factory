def command_workspace_ui(args):
    payload = workspace_ui_payload(limit=args.limit)
    output = render_workspace_ui_html(payload)
    if args.output:
        target = (ROOT / args.output).resolve()
        if ROOT not in target.parents:
            print(f"ERROR output must be inside workspace: {args.output}", file=sys.stderr)
            return 1
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(output, encoding="utf-8")
        print(f"Wrote {rel(target)}")
    else:
        print(output, end="")
    return 0


