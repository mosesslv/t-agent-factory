def yyyymmdd() -> str:
    return dt.date.today().strftime("%Y%m%d")


def markdown_link_path(path: Path) -> str:
    return rel(path).replace(".md", "")


def parse_scalar(value: str):
    value = value.strip()
    if value in {"[]", ""}:
        return [] if value == "[]" else ""
    if value in {"true", "false"}:
        return value == "true"
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [item.strip().strip("\"'") for item in inner.split(",")]
    return value.strip("\"'")


def parse_frontmatter(path: Path):
    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return None, "not utf-8 text"
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return None, "missing frontmatter"
    data = {}
    current = None
    closed = False
    for line in lines[1:]:
        if line.strip() == "---":
            closed = True
            break
        if line.startswith("  - ") and current:
            data.setdefault(current, []).append(parse_scalar(line[4:]))
            continue
        if ":" in line and not line.startswith(" "):
            key, value = line.split(":", 1)
            key = key.strip()
            value = value.strip()
            current = key
            data[key] = [] if value == "" else parse_scalar(value)
            continue
    if not closed:
        return None, "unterminated frontmatter"
    return data, None


def replace_frontmatter_value(path: Path, key: str, value: str):
    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        raise ValueError(f"{rel(path)} has no frontmatter")
    in_fm = True
    replaced = False
    output = [lines[0]]
    for line in lines[1:]:
        if in_fm and line.strip() == "---":
            if not replaced:
                output.append(f"{key}: {value}")
            output.append(line)
            in_fm = False
            continue
        if in_fm and line.startswith(f"{key}:"):
            output.append(f"{key}: {value}")
            replaced = True
            continue
        output.append(line)
    path.write_text("\n".join(output) + "\n", encoding="utf-8")


def replace_frontmatter_list(path: Path, key: str, values):
    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        raise ValueError(f"{rel(path)} has no frontmatter")
    output = [lines[0]]
    in_fm = True
    replaced = False
    skipping_list = False
    for line in lines[1:]:
        if in_fm and skipping_list and line.startswith("  - "):
            continue
        skipping_list = False
        if in_fm and line.strip() == "---":
            if not replaced:
                output.append(f"{key}:")
                output.extend(f"  - {item}" for item in values)
            output.append(line)
            in_fm = False
            continue
        if in_fm and line.startswith(f"{key}:"):
            output.append(f"{key}:")
            output.extend(f"  - {item}" for item in values)
            replaced = True
            skipping_list = True
            continue
        output.append(line)
    path.write_text("\n".join(output) + "\n", encoding="utf-8")


def markdown_files():
    ignored_parts = {".git"}
    for path in ROOT.rglob("*.md"):
        if any(part in ignored_parts for part in path.parts):
            continue
        yield path


def typed_files(include_templates=False, include_generated=False):
    for path in markdown_files():
        rel_path = rel(path)
        if not include_templates and "_meta/templates" in rel_path:
            continue
        if not include_generated and rel_path.startswith("_index/generated-"):
            continue
        data, error = parse_frontmatter(path)
        if error:
            continue
        doc_type = data.get("type")
        if doc_type:
            yield path, data


def validate_file(path: Path, data: dict):
    errors = []
    warnings = []
    doc_type = data.get("type")
    schema = SCHEMAS.get(doc_type)
    if not schema:
        warnings.append(f"unknown type: {doc_type}")
        return errors, warnings

    for field in schema["required"]:
        value = data.get(field)
        if value is None or value == "" or value == []:
            errors.append(f"missing required field: {field}")

    if "id_prefix" in schema and data.get("id") and not str(data["id"]).startswith(schema["id_prefix"]):
        errors.append(f"id must start with {schema['id_prefix']}")

    status = data.get("status")
    if status and status not in schema["statuses"]:
        errors.append(f"invalid status: {status}")

    if doc_type == "distillation-candidate":
        promotion_status = data.get("promotion_status")
        if promotion_status not in PROMOTION_STATUS_VALUES:
            errors.append(f"invalid promotion_status: {promotion_status}")
        for source in data.get("source_sessions", []):
            if not find_session(source):
                errors.append(f"source session not found: {source}")
        for debate in data.get("source_debates", []):
            if not find_debate(debate):
                errors.append(f"source debate not found: {debate}")

    if doc_type == "debate-session":
        for source in data.get("source_sessions", []):
            if not find_session(source):
                errors.append(f"source session not found: {source}")
        target = data.get("target_topic_path", "")
        if target and not str(target).startswith("主题库/"):
            errors.append(f"target_topic_path must start with 主题库/: {target}")

    if doc_type in {"knowledge-card", "decision-record"}:
        for source in data.get("source_sessions", []):
            if not find_session(source):
                errors.append(f"source session not found: {source}")

    if doc_type == "knowledge-card":
        confidence = data.get("confidence")
        if confidence and confidence not in CONFIDENCE_VALUES:
            errors.append(f"invalid confidence: {confidence}")

    return errors, warnings


def find_session(source: str):
    if not source:
        return None
    source_path = ROOT / source
    if source_path.exists():
        return source_path
    for path, data in typed_files():
        if data.get("type") == "discussion-session" and data.get("id") == source:
            return path
    return None


def find_debate(source: str):
    if not source:
        return None
    source_path = ROOT / source
    if source_path.exists():
        return source_path
    for path, data in typed_files():
        if data.get("type") == "debate-session" and data.get("id") == source:
            return path
    return None


def load_typed_path(path_arg: str, expected_type: str, label: str):
    path = (ROOT / path_arg).resolve()
    if not path.exists() or ROOT not in path.parents:
        raise ValueError(f"{label} file not found in workspace: {path_arg}")
    data, error = parse_frontmatter(path)
    if error:
        raise ValueError(f"{rel(path)}: {error}")
    if data.get("type") != expected_type:
        raise ValueError(f"{rel(path)}: not a {expected_type}")
    return path, data


def load_session_arg(session_arg: str):
    session_path = find_session(session_arg)
    if not session_path:
        raise ValueError(f"Session not found in workspace: {session_arg}")
    data, error = parse_frontmatter(session_path)
    if error:
        raise ValueError(f"{rel(session_path)}: {error}")
    if data.get("type") != "discussion-session":
        raise ValueError(f"{rel(session_path)}: not a discussion-session")
    return session_path, data


def append_linked_session_section(source_path: Path, session_path: Path, session_data: dict):
    text = source_path.read_text(encoding="utf-8")
    session_ref = f"- [[{markdown_link_path(session_path)}]] (`{session_data.get('id', '')}`)"
    if session_ref in text:
        return
    text = text.replace("- [ ] 关联到研讨 session", "- [x] 关联到研讨 session")
    if "\n## 已关联 Session\n" in text:
        text = text.rstrip() + f"\n{session_ref}\n"
    else:
        text = text.rstrip() + "\n\n## 已关联 Session\n\n" + session_ref + "\n"
    source_path.write_text(text, encoding="utf-8")


def append_review_log(path: Path, action: str, reviewer: str, note: str):
    text = path.read_text(encoding="utf-8").rstrip()
    line = f"- {today()} `{action}` by `{reviewer}`"
    if note:
        line = f"{line}: {note}"
    if "\n## 审阅记录\n" in text:
        text = f"{text}\n{line}\n"
    else:
        text = f"{text}\n\n## 审阅记录\n\n{line}\n"
    path.write_text(text, encoding="utf-8")


def command_validate(args):
    had_errors = False
    count = 0
    for path, data in typed_files():
        count += 1
        errors, warnings = validate_file(path, data)
        for warning in warnings:
            print(f"WARN {rel(path)}: {warning}")
        for error in errors:
            had_errors = True
            print(f"ERROR {rel(path)}: {error}")
    if count == 0:
        print("No typed Markdown files found.")
        return 1
    if had_errors:
        print(f"Validation failed for {count} typed files.")
        return 1
    print(f"Validation passed for {count} typed files.")
    return 0


