        return 1
    if data.get("type") != "distillation-candidate":
        print(f"ERROR {rel(path)}: not a distillation-candidate", file=sys.stderr)
        return 1

    errors, warnings = validate_file(path, data)
    checks = []
    checks.append(("type is distillation-candidate", True))
