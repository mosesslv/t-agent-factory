                },
                ensure_ascii=False,
                indent=2,
            )
        )
    else:
        mode = "confirm" if args.confirm else "preview"
        print(f"Apply source draft {mode} for {rel(path)}")
        print("Summary:")
        for item in summary_items:
            print(f"- {item}")
        print("Initial judgment:")
        for item in judgment_items:
            print(f"- {item}")
    if not args.confirm:
        if not args.json:
            print("\nNo files were written. Use --confirm to copy draft into formal sections.")
        return 0
    apply_source_draft(path)
    if not args.json:
        print("\nCopied draft into formal source sections.")
    return 0


def command_search(args):
    query = args.query.strip().lower()
    if not query:
        print("Search query is empty.", file=sys.stderr)
        return 1
    roots = args.roots or ["主题库", "_index", "_workbench", "_agents", "_meta"]
    matches = []
    for root in roots:
        base = ROOT / root
        if not base.exists():
            continue
        for path in base.rglob("*.md"):
            if "_meta/templates" in rel(path) and not args.include_templates:
                continue
            try:
                text = path.read_text(encoding="utf-8")
            except UnicodeDecodeError:
                continue
            lines = text.splitlines()
            for lineno, line in enumerate(lines, 1):
                if query in line.lower():
                    snippet = line.strip()
                    matches.append((path, lineno, snippet))
                    if len(matches) >= args.limit:
                        break
            if len(matches) >= args.limit:
                break
        if len(matches) >= args.limit:
            break
    if not matches:
        print("No matches.")
        return 0
    for path, lineno, snippet in matches:
        print(f"{rel(path)}:{lineno}: {snippet}")
    return 0


