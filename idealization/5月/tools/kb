                        {"type": row[0], "status": row[1], "topic": row[2], "path": row[3]}
                        for row in rows
                    ],
                    "pending_promotion_review": [
                        {
                            "id": data.get("id"),
                            "topic": data.get("topic"),
                            "path": rel(path),
                            "target_topic_path": data.get("target_topic_path"),
                        }
                        for path, data in pending
                    ],
                },
                ensure_ascii=False,
