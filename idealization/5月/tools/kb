    lines.extend(["", "## Safety Rules", ""])
    lines.extend(f"- {item}" for item in payload["safety_rules"])
    lines.extend(["", "## Recommended Commands", ""])
    lines.extend(f"- `{command}`" for command in payload["recommended_commands"])
