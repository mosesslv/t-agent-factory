def agent_brief_recommended_commands(review_payload):
    commands = [
        "tools/kb refresh-index",
        "tools/kb workspace-dashboard",
        "tools/kb workspace-ui > _index/generated-workspace-ui.html",
        "tools/kb decision-guide --limit 3",
        "tools/kb rag-scope --json",
        "tools/kb tool-catalog --json",
        "tools/kb review-packet --limit 3",
        "tools/kb version-status",
    ]
    distillation = next(
        (
            item
            for item in review_payload["items"]
            if item["kind"] == "distillation-candidate" and item.get("path")
        ),
        None,
    )
    if distillation:
        commands.append(f"tools/kb promote-audit {distillation['path']}")
    if review_payload["items"]:
        commands.append(review_payload["items"][0]["preview_command"])
    return commands


def agent_brief_payload(limit=5, queue=None, review_payload=None, promote_payload=None, version_payload=None):
    workbench_payload = queue if queue is not None else queue_payload()
    review_payload = review_payload if review_payload is not None else review_queue_payload(limit=limit, queue=workbench_payload)
    promote_payload = promote_payload if promote_payload is not None else promote_audit_index_payload()
    version_payload = version_payload if version_payload is not None else version_status_payload()
    top_review_tasks = review_payload["items"][:limit]
    return {
        "workspace_root": str(ROOT),
        "updated": today(),
        "mode": "read-only-handoff",
        "version_status": {
            "branch": version_payload["branch"],
            "head": version_payload["head"],
            "dirty": version_payload["dirty"],
            "changed_files": version_payload["changed_files"],
            "recent_commits": version_payload["recent_commits"][:limit],
        },
        "entrypoints": agent_brief_entrypoints(),
        "top_review_tasks": top_review_tasks,
        "promote_audit_summary": {
            "items": [
                {
                    "path": item["path"],
                    "id": item.get("id", ""),
                    "topic": item.get("topic", ""),
                    "promotion_status": item.get("promotion_status", ""),
                    "promote_ready": item.get("promote_ready", False),
                    "human_approved": item.get("human_approved", False),
                    "worktree_clean": item.get("worktree_clean", False),
                    "gate_failures": [
                        gate["name"]
                        for gate in item.get("gates", [])
                        if not gate.get("ok")
                    ],
                }
                for item in promote_payload.get("items", [])[:limit]
            ]
        },
        "safety_rules": agent_brief_safety_rules(),
        "recommended_commands": agent_brief_recommended_commands(review_payload),
    }


