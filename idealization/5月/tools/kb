def next_session_id():
    prefix = f"ws-{yyyymmdd()}-"
    nums = []
    for path, data in typed_files():
        sid = str(data.get("id", ""))
        if sid.startswith(prefix):
            try:
                nums.append(int(sid.split("-")[-1]))
            except ValueError:
                pass
    return f"{prefix}{max(nums, default=0) + 1:03d}"


