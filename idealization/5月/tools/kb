def replace_or_append_section(text: str, heading: str, body: str):
    pattern = re.compile(rf"^## {re.escape(heading)}\s*$", re.MULTILINE)
    match = pattern.search(text)
    section = f"## {heading}\n\n{body.rstrip()}\n"
    if not match:
        return text.rstrip() + "\n\n" + section
    rest = text[match.end():]
    next_heading = re.search(r"^## ", rest, re.MULTILINE)
    end = match.end() + (next_heading.start() if next_heading else len(rest))
    return text[: match.start()] + section + text[end:].lstrip("\n")


def prepare_source_note(path: Path, data: dict):
    checks = source_check_items(path, data)
    tasks = source_completion_task_lines(checks)
    status = "ready" if source_checks_pass(checks) else "needs-work"
    if tasks:
        task_lines = [f"- [ ] {task}" for task in tasks]
    else:
        task_lines = ["- [x] `check-source` 已通过，可执行 `review-source ... reviewed`。"]
    body = "\n".join(
        [
            f"- 生成日期：{today()}",
            f"- 检查状态：{status}",
            "",
            *task_lines,
        ]
    )
    text = path.read_text(encoding="utf-8")
    path.write_text(replace_or_append_section(text, "补全任务", body), encoding="utf-8")
    replace_frontmatter_value(path, "updated", today())
    if not source_checks_pass(checks):
        replace_frontmatter_value(path, "status", "draft")
        replace_frontmatter_value(path, "review_status", "needs-evidence")
    return checks, tasks


