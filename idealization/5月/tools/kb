def render_tool_catalog_markdown(payload, generated_by="tools/kb tool-catalog"):
    now = today()

    def table_cell(value):
        return str(value).replace("|", "\\|")

    lines = [
        "---",
        "type: index",
        "status: active",
        f"created: {now}",
        f"updated: {now}",
        f"generated_by: {generated_by}",
        "---",
        "",
        "# Generated Tool Catalog",
        "",
        "本文件是 Knowledge Workbench 的 MCP-ready 工具边界目录。它描述命令、资源、权限级别、写入范围和人工确认要求，不执行任何命令。",
        "",
        "## Permission Classes",
        "",
        "| Class | Risk | Auto-callable | Writes | Description |",
        "|---|---|---|---|---|",
    ]
    for item in payload["permission_classes"]:
        lines.append(
            "| {id} | {risk} | {auto} | `{writes}` | {description} |".format(
                id=table_cell(item["id"]),
                risk=table_cell(item["risk"]),
                auto=item["auto_callable"],
                writes=table_cell(", ".join(item["writes"]) or "-"),
                description=table_cell(item["description"]),
            )
        )
    lines.extend(
        [
            "",
            "## Resources",
            "",
            "| ID | Runtime | Source Command | Path | JSON |",
            "|---|---:|---|---|---|",
        ]
    )
    for item in payload["resources"]:
        lines.append(
            "| {id} | {runtime} | `{command}` | `{path}` | `{json}` |".format(
                id=table_cell(item["id"]),
                runtime=item["runtime"],
                command=table_cell(item["source_command"]),
                path=table_cell(item["path"]),
                json=table_cell(item["json_path"]),
            )
        )
    lines.extend(
        [
            "",
            "## Tools",
            "",
            "| ID | Class | Risk | Auto | Human | Confirm | Writes | Command |",
            "|---|---|---|---:|---:|---:|---|---|",
        ]
    )
    for item in payload["tools"]:
        human = item.get("requires_human_confirmation") or item.get("requires_explicit_user_intent")
        lines.append(
            "| {id} | {klass} | {risk} | {auto} | {human} | {confirm} | `{writes}` | `{command}` |".format(
                id=table_cell(item["id"]),
                klass=table_cell(item["permission_class"]),
                risk=table_cell(item["risk"]),
                auto=item["auto_callable"],
                human=human,
                confirm=item.get("requires_explicit_confirm", False),
                writes=table_cell(", ".join(item["writes"]) or "-"),
                command=table_cell(item["command"]),
            )
        )
    lines.extend(["", "## Guardrails", ""])
    lines.extend(f"- {item}" for item in payload["guardrails"])
    return "\n".join(lines).rstrip() + "\n"


