                f"- Path: `{item['path']}`",
                "",
                "### Evidence Summary",
                "",
            ]
        )
        evidence = item.get("evidence_summary", {})
        if evidence:
            for key, value in evidence.items():
                if isinstance(value, list):
                    rendered = ", ".join(value) if value else "-"
                else:
                    rendered = value
                lines.append(f"- {key}: `{rendered}`")
        else:
            lines.append("- none")
        lines.extend(
            [
                "",
                "### Decision Options",
                "",
                "| Option | When To Use | Effect | Risk | Command | Note Template |",
                "|---|---|---|---|---|---|",
            ]
        )
        for option in item.get("decision_options", []):
            lines.append(
                "| {label} | {when} | {effect} | {risk} | `{command}` | {note} |".format(
                    label=table_cell(option["label"]),
                    when=table_cell(option["when_to_use"]),
