            lines.append(f"- `{item['role']}`{runtime}: `{item['path']}` - {item['purpose']}")
    lines.extend(["", "## Top Review Tasks", ""])
    if payload["top_review_tasks"]:
        for index, item in enumerate(payload["top_review_tasks"], start=1):
            label = item.get("id") or item["path"]
            lines.extend(
                [
                    f"### {index}. {label}",
                    "",
