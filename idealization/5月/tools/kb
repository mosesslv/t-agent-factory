    if pending:
        print("\nPending promotion review:")
        for path, data in pending:
            print(f"- {data.get('id')} {data.get('topic')} {rel(path)}")
    return 0


def git_output(args):
    result = subprocess.run(
        ["git", *args],
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or "git command failed")
    return result.stdout.strip()


def version_status_payload(limit=5):
    branch = git_output(["branch", "--show-current"]) or git_output(["rev-parse", "--abbrev-ref", "HEAD"])
    head = git_output(["rev-parse", "--short", "HEAD"])
    head_full = git_output(["rev-parse", "HEAD"])
    status_lines = [
        line
        for line in git_output(["-c", "core.quotePath=false", "status", "--short"]).splitlines()
        if line.strip()
    ]
    log_lines = [line for line in git_output(["log", "--oneline", f"-n{limit}"]).splitlines() if line.strip()]
    commits = []
    for line in log_lines:
        parts = line.split(" ", 1)
        commits.append({"hash": parts[0], "subject": parts[1] if len(parts) > 1 else ""})
    return {
        "branch": branch,
        "head": head,
        "head_full": head_full,
        "dirty": bool(status_lines),
        "changed_files": status_lines,
        "recent_commits": commits,
    }


def command_version_status(args):
    try:
        payload = version_status_payload(args.limit)
    except RuntimeError as exc:
        print(f"ERROR {exc}", file=sys.stderr)
        return 1
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, indent=2))
        return 0

    print("VERSION STATUS")
    print(f"branch: {payload['branch']}")
    print(f"head: {payload['head']} {payload['recent_commits'][0]['subject'] if payload['recent_commits'] else ''}".rstrip())
    print(f"dirty: {payload['dirty']}")
    print("\nChanged files")
    if payload["changed_files"]:
        for item in payload["changed_files"]:
            print(f"- {item}")
    else:
        print("- none")
    print("\nRecent commits")
    if payload["recent_commits"]:
        for item in payload["recent_commits"]:
            print(f"- {item['hash']} {item['subject']}")
    else:
        print("- none")
    return 0


