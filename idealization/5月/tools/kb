def distillation_review_payload(path: Path, data: dict, card_id=None, decision_id=None):
    text = path.read_text(encoding="utf-8")
    checks = distillation_check_items(path, data)
    plan = build_promotion_plan(path, data, card_id, decision_id)
    check_ok = distillation_checks_pass(checks)
    no_conflicts = not plan["conflicts"]
    promotion_status = data.get("promotion_status", "")
    source_sessions = []
    for session_ref in data.get("source_sessions", []):
        session_path = find_session(session_ref)
        if session_path:
            session_data, error = parse_frontmatter(session_path)
            session_data = {} if error else session_data
            source_sessions.append(
                {
                    "ref": session_ref,
                    "path": rel(session_path),
                    "id": session_data.get("id", ""),
                    "topic": session_data.get("topic", ""),
                    "status": session_data.get("status", ""),
                    "stage": session_data.get("stage", ""),
                }
            )
        else:
            source_sessions.append({"ref": session_ref, "path": "", "id": "", "topic": "", "status": "", "stage": ""})
    source_debates = []
    for debate_ref in data.get("source_debates", []):
        debate_path = find_debate(debate_ref)
        if debate_path:
            debate_data, error = parse_frontmatter(debate_path)
            debate_data = {} if error else debate_data
            source_debates.append(
                {
                    "ref": debate_ref,
                    "path": rel(debate_path),
                    "id": debate_data.get("id", ""),
                    "topic": debate_data.get("topic", ""),
                    "status": debate_data.get("status", ""),
                    "stage": debate_data.get("stage", ""),
                }
            )
        else:
            source_debates.append({"ref": debate_ref, "path": "", "id": "", "topic": "", "status": "", "stage": ""})
    distillation_ref = rel(path)
    recommended_commands = []
    if check_ok and no_conflicts and promotion_status == "pending-human-review":
        recommended_commands.extend(
            [
                f'tools/kb review-distillation {distillation_ref} approve --note "沉淀内容和入库计划已人工确认"',
                f'tools/kb review-distillation {distillation_ref} needs-revision --note "需要补充或修订"',
                f'tools/kb review-distillation {distillation_ref} reject --note "不进入正式知识库"',
            ]
        )
    elif promotion_status == "approved-for-promotion" and no_conflicts:
        recommended_commands.append(f"tools/kb promote --confirm {distillation_ref}")
    else:
        recommended_commands.extend(
            [
                f"tools/kb check-distillation {distillation_ref}",
                f"tools/kb preview-promote {distillation_ref}",
            ]
        )
    return {
        "path": distillation_ref,
        "id": data.get("id", ""),
        "topic": data.get("topic", ""),
        "status": data.get("status", ""),
        "promotion_status": promotion_status,
        "check_ok": check_ok,
        "promotion_conflict_free": no_conflicts,
        "review_ready": check_ok and no_conflicts and promotion_status == "pending-human-review",
        "promote_ready": check_ok and no_conflicts and promotion_status == "approved-for-promotion",
        "topic_title": plan["topic_title"],
        "target_topic_path": rel(plan["target_topic_path"]),
        "stable_judgments": extract_numbered_section(text, "稳定判断"),
        "concept_definitions": extract_numbered_section(text, "概念定义"),
        "decision_candidates": extract_numbered_section(text, "决策记录候选"),
        "validation_questions": extract_bullets(extract_markdown_section(text, "待验证问题", level=2), limit=20),
        "knowledge_relationship": extract_bullets(extract_markdown_section(text, "与已有知识的关系", level=2), limit=20),
        "source_sessions": source_sessions,
        "source_debates": source_debates,
        "planned_files": [
            {
                "role": item["role"],
                "path": rel(item["path"]),
                "exists": item["exists"],
                "operation": item["operation"],
            }
            for item in plan["planned_files"]
        ],
        "conflicts": [
            {"role": item["role"], "path": rel(item["path"])}
            for item in plan["conflicts"]
        ],
        "checks": [
            {"name": name, "ok": check_ok_item, "severity": severity}
            for name, check_ok_item, severity in checks
        ],
        "recommended_commands": recommended_commands,
    }


def promote_audit_payload(path: Path, data: dict, card_id=None, decision_id=None):
    review = distillation_review_payload(path, data, card_id, decision_id)
    git_state = version_status_payload()
    distillation_ref = rel(path)
    promotion_status = data.get("promotion_status", "")
    worktree_clean = not git_state["dirty"]
    human_approved = promotion_status == "approved-for-promotion"
    promote_ready = review["check_ok"] and review["promotion_conflict_free"] and human_approved and worktree_clean
    gates = [
        {"name": "distillation checks pass", "ok": review["check_ok"], "severity": "error"},
        {"name": "promotion target has no conflicts", "ok": review["promotion_conflict_free"], "severity": "error"},
        {"name": "human review approved promotion", "ok": human_approved, "severity": "error"},
        {"name": "git worktree is clean before promote", "ok": worktree_clean, "severity": "warning"},
    ]
    commit_subject = f"docs: promote {review['topic_title']}"
    recommended_sequence = [
        f"tools/kb preview-distillation-review {distillation_ref}",
        f"tools/kb promote-audit {distillation_ref}",
    ]
    if not human_approved:
        recommended_sequence.append(
            f'tools/kb review-distillation {distillation_ref} approve --note "沉淀内容和入库计划已人工确认"'
        )
    recommended_sequence.extend(
        [
            f"tools/kb promote --confirm {distillation_ref}",
            "tools/kb refresh-index",
            "git status --short",
            "git add <promoted-files>",
            f'git commit -m "{commit_subject}"',
        ]
    )
    return {
        "path": distillation_ref,
        "id": data.get("id", ""),
        "topic": data.get("topic", ""),
        "topic_title": review["topic_title"],
        "status": data.get("status", ""),
        "promotion_status": promotion_status,
        "target_topic_path": review["target_topic_path"],
        "check_ok": review["check_ok"],
        "promotion_conflict_free": review["promotion_conflict_free"],
        "human_approved": human_approved,
        "worktree_clean": worktree_clean,
        "promote_ready": promote_ready,
        "planned_files": review["planned_files"],
        "conflicts": review["conflicts"],
        "source_sessions": review["source_sessions"],
        "source_debates": review["source_debates"],
        "checks": review["checks"],
        "gates": gates,
        "git": git_state,
        "recommended_sequence": recommended_sequence,
        "commit_subject": commit_subject,
        "rollback": {
            "preferred": "git revert <promote-commit>",
            "scope": "每次 promote 应单独提交，回退时优先 revert 该提交。",
            "knowledge_evolution": "如果结论过时，优先新增替代知识并标记旧结论 deprecated，而不是删除历史。",
        },
    }


def render_promote_audit_markdown(payload, generated_by="tools/kb promote-audit"):
    now = today()
    lines = [
        "---",
        "type: index",
        "status: active",
        f"created: {now}",
        f"updated: {now}",
        f"generated_by: {generated_by}",
        "---",
        "",
        "# Generated Promote Audit",
        "",
        "本文件用于正式入库前审计。它只展示门禁、计划写入文件、Git 状态和回退策略，不执行 approve 或 promote。",
        "",
    ]
    items = payload.get("items") if "items" in payload else [payload]
    if not items:
        lines.extend(["## Items", "", "- none"])
        return "\n".join(lines) + "\n"
    for index, item in enumerate(items, start=1):
        lines.extend(
            [
                f"## {index}. {item.get('id') or item['path']}",
                "",
                f"- Topic: `{item['topic']}`",
                f"- Title: {item['topic_title']}",
                f"- Status: `{item['status']}` / `{item['promotion_status']}`",
                f"- Target: `{item['target_topic_path']}`",
                f"- Check OK: `{item['check_ok']}`",
                f"- Conflict Free: `{item['promotion_conflict_free']}`",
                f"- Human Approved: `{item['human_approved']}`",
                f"- Worktree Clean: `{item['worktree_clean']}`",
                f"- Promote Ready: `{item['promote_ready']}`",
                "",
                "### Gates",
                "",
            ]
        )
        extend_check_lines(lines, item.get("gates", []))
        lines.extend(["", "### Planned Files", ""])
        if item.get("planned_files"):
            for planned in item["planned_files"]:
                exists = "exists" if planned.get("exists") else "new"
                lines.append(f"- {planned.get('operation', '')} `{planned.get('role', '')}` {exists} `{planned.get('path', '')}`")
        else:
            lines.append("- none")
        lines.extend(["", "### Git State", ""])
        git_state = item.get("git", {})
        lines.extend(
            [
                f"- Branch: `{git_state.get('branch', '')}`",
                f"- Head: `{git_state.get('head', '')}`",
                f"- Dirty: `{git_state.get('dirty', '')}`",
            ]
        )
        changed = git_state.get("changed_files", [])
        if changed:
            lines.append("- Changed files:")
            lines.extend(f"  - `{entry}`" for entry in changed)
        else:
            lines.append("- Changed files: none")
        lines.extend(["", "### Recommended Sequence", ""])
        for command in item.get("recommended_sequence", []):
            lines.append(f"- `{command}`")
        lines.extend(
            [
                "",
                "### Rollback",
                "",
                f"- Preferred: `{item['rollback']['preferred']}`",
                f"- Scope: {item['rollback']['scope']}",
                f"- Knowledge evolution: {item['rollback']['knowledge_evolution']}",
                "",
            ]
        )
    return "\n".join(lines).rstrip() + "\n"


def promote_audit_index_payload(rows=None):
    rows = rows if rows is not None else list(typed_files())
    items = []
    for path, data in rows:
        if (
            data.get("type") == "distillation-candidate"
            and data.get("promotion_status") in {"pending-human-review", "approved-for-promotion"}
        ):
            items.append(promote_audit_payload(path, data))
    items.sort(key=lambda item: (item["promotion_status"], item["topic"], item["path"]))
    return {"items": items}


