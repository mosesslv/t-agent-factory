def review_queue_payload(limit=None, queue=None, kind=None, ready_only=False):
    payload = queue if queue is not None else queue_payload()
    items = []
    for source in payload["source_notes"]:
        if source["check_ok"] and source["review_status"] != "reviewed":
            priority = 10
            reason = "source ready for human review"
        elif not source["check_ok"]:
            priority = 30
            reason = "source needs completion"
        else:
            priority = 90
            reason = "source already reviewed"
        items.append(
            {
                "kind": "source-note",
                "priority": priority,
                "reason": reason,
                "path": source["path"],
                "topic": source["topic"],
                "status": source["status"],
                "review_status": source["review_status"],
                "check_ok": source["check_ok"],
                "blocking_checks": source["blocking_checks"],
                "next_action": source["next_action"],
                "preview_command": source["preview_command"],
                "decision_commands": source["decision_commands"],
            }
        )
    for promotion in payload["pending_promotions"]:
        if promotion["promotion_status"] == "pending-human-review" and promotion["check_ok"] and promotion["promotion_conflict_free"]:
            priority = 20
            reason = "distillation ready for human review"
        elif promotion["promotion_status"] == "approved-for-promotion" and promotion["promotion_conflict_free"]:
            priority = 25
            reason = "distillation approved and ready for promote confirmation"
        elif not promotion["check_ok"]:
            priority = 40
            reason = "distillation checks failed"
        elif not promotion["promotion_conflict_free"]:
            priority = 45
            reason = "distillation has promotion conflicts"
        else:
            priority = 50
            reason = "distillation needs review action"
        items.append(
            {
                "kind": "distillation-candidate",
                "priority": priority,
                "reason": reason,
                "path": promotion["path"],
                "id": promotion["id"],
                "topic": promotion["topic"],
                "promotion_status": promotion["promotion_status"],
                "target_topic_path": promotion["target_topic_path"],
                "check_ok": promotion["check_ok"],
                "promotion_conflict_free": promotion["promotion_conflict_free"],
                "blocking_checks": promotion["blocking_checks"],
                "conflicts": promotion["conflicts"],
                "next_action": promotion["next_action"],
                "preview_command": promotion["preview_command"],
                "decision_commands": promotion["decision_commands"],
            }
        )
    for session in payload["active_sessions"]:
        if session["type"] != "debate-session":
            continue
        if session["next_action"] == "draft-distillation-from-debate":
            priority = 22
            reason = "debate ready to draft distillation"
        elif session["next_action"] == "set-debate-target":
            priority = 28
            reason = "debate ready but missing target topic path"
        elif session["next_action"] == "distillation-drafted":
            priority = 88
            reason = "debate already drafted a distillation"
        else:
            priority = 35
            reason = "debate needs completion"
        items.append(
            {
                "kind": "debate-session",
                "priority": priority,
                "reason": reason,
                "path": session["path"],
                "id": session["id"],
                "topic": session["topic"],
                "status": session["status"],
                "stage": session["stage"],
                "check_ok": session["check_ok"],
                "blocking_checks": session["blocking_checks"],
                "next_action": session["next_action"],
                "preview_command": session["preview_command"],
                "decision_commands": session["decision_commands"],
            }
        )
    if kind:
        items = [item for item in items if item["kind"] == kind]
    if ready_only:
        items = [item for item in items if item["priority"] < 30]
    items.sort(key=lambda item: (item["priority"], item["topic"], item["path"]))
    if limit is not None:
        items = items[:limit]
    return {"items": items}


