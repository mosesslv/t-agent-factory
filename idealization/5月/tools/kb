def draft_source_summary(path: Path, data: dict):
    sessions = session_paths_for_source(path)
    source_title = data.get("source_title", rel(path))
    summary_items = []
    judgment_items = []
    source_links = []
    for session_path in sessions:
        session_text = session_path.read_text(encoding="utf-8")
        session_data, _ = parse_frontmatter(session_path)
        session_id = session_data.get("id", rel(session_path)) if session_data else rel(session_path)
        source_links.append(f"- [[{markdown_link_path(session_path)}]] (`{session_id}`)")
        issue = extract_markdown_section(session_text, "议题", level=2).strip()
        if issue:
            summary_items.append(f"该来源与研讨议题相关：{issue.splitlines()[0].strip()}")
        conclusions = extract_markdown_section(session_text, "共识", level=3)
        if not conclusions:
            conclusions = extract_markdown_section(session_text, "阶段结论", level=2)
        for item in extract_bullets(conclusions, limit=3):
            summary_items.append(item)
        assumptions = extract_markdown_section(session_text, "待验证假设", level=3)
        if not assumptions:
            assumptions = extract_markdown_section(session_text, "待验证问题", level=2)
        for item in extract_bullets(assumptions, limit=2):
            judgment_items.append(f"待验证：{item}")

    if not summary_items:
        summary_items = [f"该来源 `{source_title}` 已关联到研讨 session，但仍缺少可复用摘要。"]
    if not judgment_items:
        judgment_items = [
            "可信度：medium，来自已关联 session 的阶段性研讨上下文，仍需人工确认。",
            "与当前知识库关系：用于补充来源资料，不直接代表正式知识。",
            "是否建议进入 session：是，已作为 session source input。",
        ]
    else:
        judgment_items = [
            "可信度：medium，来自已关联 session 的阶段性研讨上下文，仍需人工确认。",
            "与当前知识库关系：用于补充来源资料，不直接代表正式知识。",
            "是否建议进入 session：是，已作为 session source input。",
            *judgment_items,
        ]

    body = "\n".join(
        [
            f"- 生成日期：{today()}",
            "- 生成方式：从已关联 session 提取上下文；需人工审阅后再复制到正式 `## 摘要` 和 `## 初步判断`。",
            "",
            "### 摘要候选",
            "",
            *[f"- {item}" for item in summary_items[:5]],
            "",
            "### 初步判断候选",
            "",
            *[f"- {item}" for item in judgment_items[:6]],
            "",
            "### 关联 Session",
            "",
            *(source_links or ["- 未找到关联 session"]),
        ]
    )
    text = path.read_text(encoding="utf-8")
    path.write_text(replace_or_append_section(text, "摘要草稿", body), encoding="utf-8")
    replace_frontmatter_value(path, "updated", today())
    return {"summary_items": summary_items[:5], "judgment_items": judgment_items[:6], "sessions": [rel(item) for item in sessions]}


def parse_source_draft(path: Path):
    text = path.read_text(encoding="utf-8")
    draft = extract_markdown_section(text, "摘要草稿", level=2)
    if not draft:
        return [], []
    summary = extract_markdown_section(draft, "摘要候选", level=3)
    judgment = extract_markdown_section(draft, "初步判断候选", level=3)
    return extract_bullets(summary, limit=20), extract_bullets(judgment, limit=20)


def apply_source_draft(path: Path):
    summary_items, judgment_items = parse_source_draft(path)
    if not summary_items or not judgment_items:
        raise ValueError(f"{rel(path)} has no usable 摘要草稿")
    text = path.read_text(encoding="utf-8")
    text = replace_or_append_section(text, "摘要", "\n".join(f"- {item}" for item in summary_items))
    text = replace_or_append_section(text, "初步判断", "\n".join(f"- {item}" for item in judgment_items))
    path.write_text(text, encoding="utf-8")
    replace_frontmatter_value(path, "updated", today())
    replace_frontmatter_value(path, "status", "draft")
    replace_frontmatter_value(path, "review_status", "draft-summary-applied")
    return summary_items, judgment_items


def distillation_check_items(path: Path, data: dict):
    text = path.read_text(encoding="utf-8")
    errors, warnings = validate_file(path, data)
    target = data.get("target_topic_path", "")
    stable_claims = extract_numbered_section(text, "稳定判断")
    definitions = extract_numbered_section(text, "概念定义")
    decisions = extract_numbered_section(text, "决策记录候选")
    validation_questions = extract_markdown_section(text, "待验证问题", level=2)
    knowledge_relation = extract_markdown_section(text, "与已有知识的关系", level=2)
    promote_suggestion = extract_markdown_section(text, "Promote 建议", level=2)

    checks = [
        ("type is distillation-candidate", data.get("type") == "distillation-candidate", "error"),
        ("schema validation passes", not errors, "error"),
        ("promotion_status is reviewable", data.get("promotion_status") in {"pending-human-review", "approved-for-promotion"}, "error"),
        ("source_sessions are set", bool(data.get("source_sessions")), "error"),
        ("source_sessions exist", not any("source session not found" in error for error in errors), "error"),
        ("source_debates exist when set", not any("source debate not found" in error for error in errors), "error"),
        ("target_topic_path is under 主题库/", bool(target) and str(target).startswith("主题库/"), "error"),
        ("stable judgments are present", len(stable_claims) >= 1, "error"),
        ("concept definitions are present", len(definitions) >= 1, "error"),
        ("decision candidates are present", len(decisions) >= 1, "error"),
        ("validation questions are present", has_list_content(validation_questions), "warning"),
        ("knowledge relationship section is present", has_list_content(knowledge_relation), "warning"),
        ("human confirmation is stated", "是" in promote_suggestion or "人工确认" in promote_suggestion, "warning"),
    ]
    for error in errors:
        checks.append((f"validation error: {error}", False, "error"))
    for warning in warnings:
        checks.append((f"validation warning: {warning}", False, "warning"))
    return checks


def distillation_checks_pass(checks):
    return all(ok for _, ok, severity in checks if severity == "error")


def print_distillation_checks(path: Path, checks):
    print(f"Check distillation for {rel(path)}")
    for name, ok, severity in checks:
        if ok:
            label = "PASS"
        elif severity == "warning":
            label = "WARN"
        else:
            label = "FAIL"
        print(f"{label} {name}")


def extract_title(text: str, fallback: str):
    for line in text.splitlines():
        if line.startswith("# "):
            title = line[2:].strip()
            return title.replace("沉淀候选：", "").strip() or fallback
    return fallback


def build_promotion_plan(path: Path, data: dict, card_id=None, decision_id=None):
    text = path.read_text(encoding="utf-8")
    target = ROOT / data["target_topic_path"]
    professional = target / "专业知识"
    decisions = target / "决策记录"
    topic_title = extract_title(text, target.name)
    stable_claims = extract_numbered_section(text, "稳定判断")
    definitions = extract_numbered_section(text, "概念定义")
    decision_items = extract_numbered_section(text, "决策记录候选")
    card = professional / f"01-{slugify(topic_title)}.md"
    decision = decisions / f"ADR-001-{slugify(decision_items[0] if decision_items else topic_title)}.md"
    readme = target / "README.md"
    planned_files = [
        {"role": "topic-index", "path": readme, "exists": readme.exists(), "operation": "append" if readme.exists() else "create"},
        {"role": "knowledge-card", "path": card, "exists": card.exists(), "operation": "create"},
        {"role": "decision-record", "path": decision, "exists": decision.exists(), "operation": "create"},
        {"role": "distillation-candidate", "path": path, "exists": True, "operation": "update-status-on-confirm"},
    ]
    return {
        "distillation": path,
        "topic": data.get("topic", ""),
        "topic_title": topic_title,
        "target_topic_path": target,
        "source_sessions": data.get("source_sessions", []),
        "card_id": card_id or next_doc_id("kc"),
        "decision_id": decision_id or next_doc_id("adr"),
        "stable_claim_count": len(stable_claims),
        "definition_count": len(definitions),
        "decision_count": len(decision_items),
        "planned_files": planned_files,
        "conflicts": [
            item for item in planned_files
            if item["role"] in {"knowledge-card", "decision-record"} and item["exists"]
        ],
    }


